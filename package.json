{
  "name": "fertilizer",
  "version": "0.0.1",
  "displayName": "Fertilizer",
  "author": "Thomas Pfeiffer",
  "description": "Web extension to enhance Harvest UI",
  "scripts": {
    "build": "tsc && vite build",
    "watch": "vite build --watch",
    "dev": "run-p dev:vite serve:chrome",
    "dev:vite": "vite",
    "test": "jest",
    "serve:firefox": "web-ext run --start-url \"https://lise.harvestapp.com/time\"  --source-dir ./dist/",
    "serve:chrome": "web-ext run -t chromium --start-url \"https://lise.harvestapp.com/time\" --source-dir ./dist/"
  },
  "license": "MIT",
  "devDependencies": {
    "@samrum/vite-plugin-web-extension": "^5.1.0",
    "@types/chrome": "^0.0.268",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.10",
    "@types/webextension-polyfill": "^0.10.7",
    "jest": "^29.7.0",
    "mockdate": "^3.0.5",
    "npm-run-all": "^4.1.5",
    "prettier": "3.3.2",
    "ts-jest": "^29.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3",
    "vite": "~5.3.3",
    "web-ext": "^8.2.0"
  },
  "dependencies": {
    "dayjs": "^1.11.11",
    "emoji-regex": "^10.3.0",
    "jest-environment-jsdom": "^29.7.0",
    "webextension-polyfill": "^0.12.0"
  },
  "engines": {
    "npm": ">=10.0.0",
    "node": ">=22.0.0"
  }
}
